{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aelf-skills.dev/schemas/skills-catalog.schema.json",
  "title": "aelf-skills catalog",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "source", "skills", "warnings"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.3.0"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "displayName",
          "npm",
          "repository",
          "description",
          "capabilities",
          "artifacts",
          "setupCommands",
          "clientSupport",
          "openclawToolCount"
        ],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "npm": {
            "type": "object",
            "required": ["name", "version"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 }
            }
          },
          "repository": {
            "type": "object",
            "properties": {
              "https": { "type": "string", "format": "uri" }
            }
          },
          "description": { "type": "string", "minLength": 1 },
          "description_zh": { "type": "string" },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "artifacts": {
            "type": "object",
            "required": ["skillMd", "mcpServer", "openclaw"],
            "properties": {
              "skillMd": { "type": "boolean" },
              "mcpServer": { "type": "boolean" },
              "openclaw": { "type": "boolean" }
            }
          },
          "setupCommands": {
            "type": "object",
            "required": ["install"],
            "properties": {
              "install": { "type": "string" },
              "list": { "type": "string" },
              "openclaw": { "type": "string" },
              "cursor": { "type": "string" },
              "claudeDesktop": { "type": "string" },
              "ironclaw": { "type": "string" }
            }
          },
          "clientSupport": {
            "type": "object",
            "required": ["openclaw", "cursor", "claude_desktop", "ironclaw", "claude_code", "codex"],
            "properties": {
              "openclaw": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "cursor": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "claude_desktop": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "ironclaw": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "claude_code": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "codex": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              }
            }
          },
          "openclawToolCount": {
            "type": "integer",
            "minimum": 0
          },
          "dependsOn": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "sourcePath": {
            "type": "string"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
