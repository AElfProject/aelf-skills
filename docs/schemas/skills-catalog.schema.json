{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aelf-skills.dev/schemas/skills-catalog.schema.json",
  "title": "aelf-skills catalog",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "source", "skills", "warnings"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.4.0"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "displayName",
          "npm",
          "repository",
          "distributionSources",
          "description",
          "capabilities",
          "artifacts",
          "setupCommands",
          "clientSupport",
          "clientInstall",
          "openclawToolCount"
        ],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "npm": {
            "type": "object",
            "required": ["name", "version"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 }
            }
          },
          "repository": {
            "type": "object",
            "properties": {
              "https": { "type": "string", "format": "uri" }
            }
          },
          "distributionSources": {
            "type": "object",
            "required": ["npmPackage"],
            "properties": {
              "githubRepo": { "type": "string", "format": "uri" },
              "npmPackage": { "type": "string", "minLength": 1 },
              "clawhubId": { "type": "string", "minLength": 1 }
            }
          },
          "description": { "type": "string", "minLength": 1 },
          "description_zh": { "type": "string" },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "artifacts": {
            "type": "object",
            "required": ["skillMd", "mcpServer", "openclaw", "ironclawWasm"],
            "properties": {
              "skillMd": { "type": "boolean" },
              "mcpServer": { "type": "boolean" },
              "openclaw": { "type": "boolean" },
              "ironclawWasm": { "type": "boolean" }
            }
          },
          "setupCommands": {
            "type": "object",
            "required": ["install"],
            "properties": {
              "install": { "type": "string" },
              "list": { "type": "string" },
              "openclaw": { "type": "string" },
              "cursor": { "type": "string" },
              "claudeDesktop": { "type": "string" },
              "ironclaw": { "type": "string" }
            }
          },
          "clientSupport": {
            "type": "object",
            "required": ["openclaw", "cursor", "claude_desktop", "ironclaw", "claude_code", "codex"],
            "properties": {
              "openclaw": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "cursor": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "claude_desktop": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "ironclaw": {
                "type": "string",
                "description": "Schema remains backward compatible, but the current wasm-only IronClaw rollout only permits native or unsupported at runtime.",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "claude_code": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              },
              "codex": {
                "type": "string",
                "enum": ["native", "native-setup", "manual-mcp", "manual-cli-or-mcp", "manual", "unsupported"]
              }
            }
          },
          "clientInstall": {
            "type": "object",
            "required": ["openclaw", "ironclaw"],
            "properties": {
              "openclaw": {
                "type": "object",
                "required": ["source", "mode"],
                "properties": {
                  "source": {
                    "type": "string",
                    "enum": ["clawhub", "npm", "none"]
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["managed-install", "package-setup", "trusted-local-install", "unsupported"]
                  },
                  "installCommand": { "type": "string" },
                  "requiresTrustPromotion": {
                    "type": "boolean",
                    "description": "Reserved for future trust-promotion flows; not consumed in the current rollout."
                  }
                }
              },
              "ironclaw": {
                "type": "object",
                "required": ["source", "mode"],
                "properties": {
                  "source": {
                    "type": "string",
                    "enum": ["clawhub", "npm", "none"]
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["managed-install", "package-setup", "trusted-local-install", "unsupported"]
                  },
                  "installCommand": { "type": "string" },
                  "requiresTrustPromotion": {
                    "type": "boolean",
                    "description": "Reserved for future trust-promotion flows; not consumed in the current rollout."
                  }
                }
              }
            }
          },
          "ironclawNative": {
            "type": "object",
            "required": [
              "runtime",
              "distribution",
              "artifactUrl",
              "capabilitiesUrl",
              "installCommand",
              "stateModel",
              "stability"
            ],
            "properties": {
              "runtime": {
                "type": "string",
                "enum": ["wasm-tool"]
              },
              "distribution": {
                "type": "string",
                "enum": ["github-release"]
              },
              "artifactUrl": { "type": "string", "format": "uri" },
              "capabilitiesUrl": { "type": "string", "format": "uri" },
              "installCommand": { "type": "string", "minLength": 1 },
              "stateModel": {
                "type": "string",
                "enum": ["isolated"]
              },
              "stability": {
                "type": "string",
                "enum": ["experimental", "stable"]
              }
            }
          },
          "clawhub": {
            "type": "object",
            "required": ["slug", "role"],
            "properties": {
              "slug": { "type": "string", "minLength": 1 },
              "role": {
                "type": "string",
                "enum": ["discovery-shell", "runtime-skill"]
              }
            }
          },
          "openclawToolCount": {
            "type": "integer",
            "minimum": 0
          },
          "dependsOn": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "sourcePath": {
            "type": "string"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
