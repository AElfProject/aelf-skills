{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aelf-skills.dev/schemas/openclaw.schema.json",
  "title": "OpenClaw tool manifest",
  "type": "object",
  "required": ["name", "description", "tools"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "command", "args", "cwd", "inputSchema"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "args": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cwd": { "type": "string" },
          "inputSchema": {
            "type": "object"
          }
        }
      }
    }
  }
}
