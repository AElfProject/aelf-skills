{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aelf-skills.dev/schemas/skill-frontmatter.schema.json",
  "title": "SKILL.md Front Matter",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical skill id source."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Optional skill/package version string for routing/runtime compatibility."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Primary English description used by catalog generation."
    },
    "description_zh": {
      "type": "string",
      "minLength": 1,
      "description": "Optional Chinese description for README.zh-CN table rendering."
    },
    "activation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "keywords": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "exclude_keywords": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "max_context_tokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
