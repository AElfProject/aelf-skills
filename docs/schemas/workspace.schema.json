{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aelf-skills.dev/schemas/workspace.schema.json",
  "title": "aelf-skills workspace.json",
  "type": "object",
  "required": ["projects"],
  "additionalProperties": false,
  "properties": {
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute, relative, or env-expanded path (for example ${SKILLS_BASE}/AElf/aelf-node-skill)."
          },
          "dependsOn": {
            "type": "array",
            "description": "Optional direct dependencies by skill id.",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
